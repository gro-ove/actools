<UserControl x:Class="AcManager.Pages.Drive.CspNewModes" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mui="http://firstfloorsoftware.com/ModernUI"
    xmlns:dr="clr-namespace:AcManager.Pages.Drive" xmlns:g="clr-namespace:AcManager" xmlns:c="http://acstuff.club/app/controls"
    xmlns:t="http://acstuff.club/app/tools" xmlns:uc="clr-namespace:AcManager.UserControls" xmlns:a="clr-namespace:AcTools;assembly=AcTools" mc:Ignorable="d"
    d:DesignHeight="600" d:DesignWidth="900" d:DataContext="{d:DesignInstance dr:CspNewModes+ViewModel}" Loaded="OnLoaded" Unloaded="OnUnloaded" x:Name="This">
  <UserControl.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <mui:SharedResourceDictionary Source="/AcManager.Controls;component/Assets/AcSpecific.xaml" />
        <mui:SharedResourceDictionary Source="/AcManager.Controls;component/Assets/AcSettingsSpecific.xaml" />
        <mui:SharedResourceDictionary Source="/AcManager.Controls;component/Assets/SettingsSpecific.xaml" />
        <mui:SharedResourceDictionary Source="/AcManager.Controls;component/Assets/IconData.xaml" />
      </ResourceDictionary.MergedDictionaries>

      <Thickness x:Key="ElementMargin">0 0 8 8</Thickness>

      <!-- PythonAppConfig templates (from QuickDrive_Custom) -->
      <ItemsPanelTemplate x:Key="PythonAppConfig.RaceSectionItemsPanel">
        <mui:UniformGridWithOrientation Orientation="Horizontal" VerticalSpacing="0" HorizontalSpacing="0" Columns="2" />
      </ItemsPanelTemplate>

      <DataTemplate x:Key="PythonAppConfig.RaceItemTemplate" DataType="t:IPythonAppConfigValue">
        <Border mui:ContextMenuAdvancement.PropagateToChildren="True" Background="Transparent">
          <FrameworkElement.ContextMenu>
            <ContextMenu IsEnabled="{Binding IsResettable}">
              <MenuItem Header="{x:Static c:ControlsStrings.Common_Reset}" Command="{Binding ResetCommand}" IsEnabled="{Binding IsNonDefault}" />
            </ContextMenu>
          </FrameworkElement.ContextMenu>
          <ContentControl Content="{Binding}" IsEnabled="{Binding IsEnabled}">
            <ContentControl.ToolTip>
              <ToolTip
                  Visibility="{Binding ToolTip.Length, Converter={StaticResource MoreToVisibilityConverter}, FallbackValue={x:Static Visibility.Collapsed}}">
                <ToolTip.Content>
                  <TextBlock MaxWidth="400" TextWrapping="Wrap" Text="{Binding ToolTip}" />
                </ToolTip.Content>
              </ToolTip>
            </ContentControl.ToolTip>
            <ContentControl.Resources>
              <DataTemplate DataType="{x:Type t:PythonAppConfigBoolValue}">
                <StackPanel Margin="{StaticResource ElementMargin}" Height="42">
                  <CheckBox Margin="8 8 0 0" IsChecked="{Binding Value}" mui:NewMarkService.New="{Binding IsNew}">
                    <Label Content="{Binding DisplayName}" />
                  </CheckBox>
                </StackPanel>
              </DataTemplate>
              <DataTemplate DataType="{x:Type t:PythonAppConfigRangeValue}">
                <StackPanel Margin="{StaticResource ElementMargin}" Height="42">
                  <mui:ValueLabel Content="{Binding DisplayName}" Value="{Binding DisplayValue}" mui:BetterTextBox.Mode="Number"
                      Postfix="{Binding DisplayPostix}" />
                  <Slider Minimum="{Binding Minimum.Value}" Maximum="{Binding Maximum.Value}" Value="{Binding Value}" TickFrequency="{Binding Tick}"
                      TickPlacement="BottomRight" mui:NewMarkService.New="{Binding IsNew}" />
                </StackPanel>
              </DataTemplate>
              <DataTemplate DataType="{x:Type t:PythonAppConfigNumberValue}">
                <StackPanel Margin="{StaticResource ElementMargin}" Height="42">
                  <TextBlock Style="{StaticResource Label.Padding}"
                      Text="{Binding DisplayName, StringFormat={x:Static mui:ColonConverter.FormatNoSpaceAfterwards}}" Margin="0 0 0 4" />
                  <mui:BetterTextBox Text="{Binding Value}" Mode="Number" Placeholder="?" Margin="4 0 4 0" mui:NewMarkService.New="{Binding IsNew}" />
                </StackPanel>
              </DataTemplate>
              <DataTemplate DataType="{x:Type t:PythonAppConfigOptionsValue}">
                <StackPanel Margin="{StaticResource ElementMargin}" Height="42">
                  <TextBlock Style="{StaticResource Label.Padding}"
                      Text="{Binding DisplayName, StringFormat={x:Static mui:ColonConverter.FormatNoSpaceAfterwards}}" Margin="0 0 0 4" />
                  <mui:BetterComboBox ItemsSource="{Binding Values}" SelectedItem="{Binding Value, Mode=TwoWay}" IsEditable="False" Margin="4 0 4 0"
                      mui:NewMarkService.New="{Binding IsNew}">
                    <mui:BetterComboBox.ItemTemplateSelector>
                      <t:PythonAppConfigOptionsTemplateSelector>
                        <t:PythonAppConfigOptionsTemplateSelector.NullTemplate>
                          <DataTemplate>
                            <Separator Background="{DynamicResource SeparatorBackground}" />
                          </DataTemplate>
                        </t:PythonAppConfigOptionsTemplateSelector.NullTemplate>
                        <t:PythonAppConfigOptionsTemplateSelector.DataTemplate>
                          <DataTemplate>
                            <TextBlock Text="{Binding DisplayName}" />
                          </DataTemplate>
                        </t:PythonAppConfigOptionsTemplateSelector.DataTemplate>
                      </t:PythonAppConfigOptionsTemplateSelector>
                    </mui:BetterComboBox.ItemTemplateSelector>
                  </mui:BetterComboBox>
                </StackPanel>
              </DataTemplate>
              <DataTemplate DataType="{x:Type t:PythonAppConfigValue}">
                <StackPanel Margin="{StaticResource ElementMargin}" Height="42">
                  <TextBlock Style="{StaticResource Label.Padding}"
                      Text="{Binding DisplayName, StringFormat={x:Static mui:ColonConverter.FormatNoSpaceAfterwards}}" Margin="0 0 0 4" />
                  <mui:BetterTextBox Text="{Binding Value}" Placeholder="?" Margin="4 0 4 0" mui:NewMarkService.New="{Binding IsNew}" />
                </StackPanel>
              </DataTemplate>
              <DataTemplate DataType="{x:Type t:PythonAppConfigFileValue}">
                <StackPanel Margin="{StaticResource ElementMargin}" Height="42">
                  <TextBlock Style="{StaticResource Label.Padding}"
                      Text="{Binding DisplayName, StringFormat={x:Static mui:ColonConverter.FormatNoSpaceAfterwards}}" Margin="0 0 0 4" />
                  <DockPanel Margin="4 0 4 0">
                    <Button Padding="4 2" Margin="2 0 0 0" Content="…" Command="{Binding ChangeFileCommand}" DockPanel.Dock="Right" />
                    <mui:PathTrimmingTextBlock MinWidth="1" Text="{Binding Value}" Placeholder="?" mui:NewMarkService.New="{Binding IsNew}" />
                  </DockPanel>
                </StackPanel>
              </DataTemplate>
            </ContentControl.Resources>
          </ContentControl>
        </Border>
      </DataTemplate>

      <DataTemplate x:Key="PythonAppConfig.Compact.RaceSectionTemplate" DataType="{x:Type t:PythonAppConfigSection}">
        <DockPanel>
          <TextBlock Text="{Binding DisplayName, StringFormat={x:Static mui:ColonConverter.FormatNoSpaceAfterwards}}" DockPanel.Dock="Top" Margin="0 0 0 8"
              TextWrapping="Wrap" Style="{StaticResource Label}" ToolTip="{Binding ToolTip}"
              Visibility="{Binding IsSingleSection, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=inverse}" />
          <c:MessageBlock DockPanel.Dock="Top" Margin="0 0 0 8"
              Visibility="{Binding HintTop, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=inverse}">
            <mui:BbCodeBlock Text="{Binding HintTop}" Style="{StaticResource Small}" />
          </c:MessageBlock>
          <c:MessageBlock DockPanel.Dock="Bottom" Margin="0 8 0 0"
              Visibility="{Binding HintBottom, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=inverse}">
            <mui:BbCodeBlock Text="{Binding HintBottom}" Style="{StaticResource Small}" />
          </c:MessageBlock>
          <ItemsControl ItemsSource="{Binding}" ItemTemplate="{StaticResource PythonAppConfig.RaceItemTemplate}"
              ItemContainerStyle="{StaticResource PythonAppConfig.ItemContainerStyle}" ItemsPanel="{StaticResource PythonAppConfig.RaceSectionItemsPanel}" />
        </DockPanel>
      </DataTemplate>

      <DataTemplate x:Key="PythonAppConfig.Compact.Race" DataType="{x:Type t:PythonAppConfig}">
        <ItemsControl ItemsSource="{Binding SectionsOwn}" ItemTemplate="{StaticResource PythonAppConfig.Compact.RaceSectionTemplate}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <mui:SpacingStackPanel Spacing="20" Orientation="Vertical" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
        </ItemsControl>
      </DataTemplate>
    </ResourceDictionary>
  </UserControl.Resources>

  <mui:Switch Value="{Binding Modes.Count}" Style="{StaticResource ContentRoot}">
    <!-- Empty state -->
    <mui:Cell mui:Switch.When="0">
      <!-- TODO better warning, hide the thing too -->
      <TextBlock Text="No new modes available" Style="{StaticResource Heading1}" TextAlignment="Center" HorizontalAlignment="Center" VerticalAlignment="Center" />
    </mui:Cell>

    <!-- Main content -->
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition MinWidth="100" />
        <ColumnDefinition Width="29" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <ListBox x:Name="ModeListBox" ItemsSource="{Binding Modes}" SelectedItem="{Binding SelectedMode}" ScrollViewer.VerticalScrollBarVisibility="Auto"
          ScrollViewer.HorizontalScrollBarVisibility="Disabled" mui:FancyScroll.Outside="True" ItemContainerStyle="{StaticResource RibbonListBoxItem.Left}">
        <ListBox.ItemTemplate>
          <DataTemplate DataType="{x:Type t:NewRaceModeData}">
            <DockPanel Height="48" Margin="12 0 0 0">
              <DockPanel.ToolTip>
                <ToolTip Content="{Binding ToolTipContent}" />
              </DockPanel.ToolTip>
              <TextBlock DockPanel.Dock="Top" Text="{Binding DisplayName}" Style="{StaticResource Heading2}" TextTrimming="CharacterEllipsis" />
              <TextBlock Text="{Binding Description}" Style="{StaticResource Small}" FontWeight="Normal" TextTrimming="CharacterEllipsis" Margin="0 4 0 0"
                  TextWrapping="NoWrap" />
            </DockPanel>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>

      <mui:ModernTabSplitter Grid.Column="1" SaveKey="CarSelectionDialog" InitialWidth="320" AdjustRightColumn="True" Panel.ZIndex="-1" />

      <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
          Visibility="{Binding HasSelectedMode, Converter={StaticResource BooleanToVisibilityConverter}}">
        <mui:SpacingStackPanel Spacing="16">

          <!-- Mode info -->
          <StackPanel>
            <TextBlock Text="{Binding SelectedMode.DisplayName}" Style="{StaticResource Heading1}" Margin="0 0 0 4" />
            <mui:SpacingStackPanel Orientation="Horizontal" Spacing="16">
              <TextBlock Style="{StaticResource Small}"
                  Visibility="{Binding SelectedMode.Author, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=inverse}">
                <Run Text="Author:" /><Run Text="{Binding SelectedMode.Author, Mode=OneWay}" FontWeight="Bold" />
              </TextBlock>
              <TextBlock Style="{StaticResource Small}"
                  Visibility="{Binding SelectedMode.Version, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=inverse}">
                <Run Text="Version:" /><Run Text="{Binding SelectedMode.Version, Mode=OneWay}" FontWeight="Bold" />
              </TextBlock>
            </mui:SpacingStackPanel>
            <TextBlock Text="{Binding SelectedMode.Description}" TextWrapping="Wrap" Margin="0 8 0 0" Opacity="0.8"
                Visibility="{Binding SelectedMode.Description, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=inverse}" />
          </StackPanel>

          <!-- Mode detailed description -->
          <c:MessageBlock CloseKey="{Binding ModeViewModel.ID, StringFormat='{}.newmode.description:{0}'}" Margin="0 0 0 0"
              Visibility="{Binding ModeViewModel.DetailedDescription, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=inverse}">
            <mui:BbCodeBlock Text="{Binding ModeViewModel.DetailedDescription}" Mode="Extended" />
          </c:MessageBlock>

          <!-- Car and Track selection -->
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="16" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Car -->
            <mui:Cell Grid.Column="0" Height="140" Background="{DynamicResource CardBackground}" ClipToBounds="True" MouseLeftButtonUp="OnCarBlockClick"
                Cursor="Hand" c:ToolTips.Car="{Binding SelectedCar}">
              <TextBlock Style="{StaticResource Title}" Text="{x:Static g:AppStrings.QuickDrive_NoCarSelected}"
                  Foreground="{DynamicResource CardHeaderTextDisabled}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0 0 0 20"
                  Visibility="{Binding SelectedCar, Converter={StaticResource NullToVisibilityConverter}}" />
              <mui:BetterImage Filename="{Binding SelectedCar.SelectedSkin.PreviewImage}" DecodeWidth="320" Stretch="UniformToFill" />
              <DockPanel Background="{DynamicResource DarkStripeBackground}" VerticalAlignment="Bottom" TextBlock.Foreground="{DynamicResource DarkStripeText}">
                <mui:BetterImage Filename="{Binding SelectedCar.BrandBadge}" Width="16" Height="16" Margin="4 4 0 4"
                    Visibility="{Binding SelectedCar, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=inverse}" />
                <TextBlock Text="{Binding SelectedCar.DisplayName}" Padding="4" TextTrimming="CharacterEllipsis" />
              </DockPanel>
            </mui:Cell>

            <!-- Track -->
            <mui:Cell Grid.Column="2" Height="140" Background="{DynamicResource CardBackground}" ClipToBounds="True" MouseLeftButtonUp="OnTrackBlockClick"
                Cursor="Hand" c:ToolTips.Track="{Binding SelectedTrack}">
              <TextBlock Style="{StaticResource Title}" Text="{x:Static g:AppStrings.QuickDrive_NoTrackSelected}"
                  Foreground="{DynamicResource CardHeaderTextDisabled}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0 0 0 20"
                  Visibility="{Binding SelectedTrack, Converter={StaticResource NullToVisibilityConverter}}" />
              <mui:BetterImage Filename="{Binding SelectedTrack.PreviewImage}" DecodeWidth="{Binding Source={x:Static a:CommonAcConsts.TrackPreviewWidth}}"
                  Stretch="UniformToFill" />
              <mui:BetterImage Filename="{Binding SelectedTrack.OutlineImage}" DecodeWidth="{Binding Source={x:Static a:CommonAcConsts.TrackOutlineWidth}}"
                  ShowBroken="False" />
              <DockPanel Background="{DynamicResource DarkStripeBackground}" VerticalAlignment="Bottom" TextBlock.Foreground="{DynamicResource DarkStripeText}">
                <TextBlock Text="{Binding SelectedTrack.Name}" Padding="4" TextTrimming="CharacterEllipsis" />
              </DockPanel>
            </mui:Cell>
          </Grid>

          <!-- Conditions -->
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Time -->
            <StackPanel Margin="0 0 8 8" Grid.Row="0" Grid.Column="0">
              <mui:ValueLabel Value="{Binding Time}" mui:BetterTextBox.Mode="Time" Content="{x:Static g:AppStrings.Drive_Time}" Margin="0 0 0 4" />
              <Slider Minimum="0" Maximum="86399" Value="{Binding Time}" TickFrequency="3600" TickPlacement="BottomRight" IsSnapToTickEnabled="False"
                  SmallChange="900" LargeChange="1800" />
            </StackPanel>

            <!-- Weather -->
            <StackPanel Margin="0 0 8 8" Grid.Row="0" Grid.Column="1">
              <TextBlock Text="{x:Static g:AppStrings.Drive_WeatherLabel}" Style="{StaticResource Label.Padding}" Margin="0 0 0 4" />
              <c:WeatherComboBox SelectedItem="{Binding SelectedWeather}" AllowRandomWeather="True" AllowWeatherByType="True"
                  c:ToolTips.Weather="{Binding SelectedWeatherObject}" UseWeatherFX="True" />
            </StackPanel>

            <!-- Temperature -->
            <StackPanel Margin="0 0 8 8" Grid.Row="0" Grid.Column="2">
              <c:TemperatureValueLabel Value="{Binding Temperature, StringFormat='\{0:F1\}'}" Background="Transparent"
                  Content="{x:Static g:AppStrings.Drive_Temperature}" Margin="0 0 0 4">
                <mui:ValueLabel.ToolTip>
                  <c:TemperatureBlock Prefix="{x:Static g:AppStrings.Common_RoadTemperature}" Rounding="0.1" Text="{Binding RoadTemperature}" />
                </mui:ValueLabel.ToolTip>
              </c:TemperatureValueLabel>
              <Slider Minimum="{x:Static a:CommonAcConsts.TemperatureMinimum}" Maximum="{x:Static a:CommonAcConsts.TemperatureMaximum}"
                  Value="{Binding Temperature}" TickFrequency="6" IsSnapToTickEnabled="False" TickPlacement="BottomRight" SmallChange="5" LargeChange="5" />
            </StackPanel>

            <!-- Track state -->
            <StackPanel Margin="0 0 8 8" Grid.Row="1" Grid.Column="0">
              <TextBlock Text="{x:Static g:AppStrings.Drive_TrackStateLabel}" Style="{StaticResource Label.Padding}" Margin="0 0 0 4" />
              <c:UserPresetsControl UserPresetable="{Binding TrackState}" ShowSaveButton="False" />
            </StackPanel>

            <!-- Wind -->
            <StackPanel Margin="0 0 8 8" Grid.Row="1" Grid.Column="1">
              <mui:DoubleValueLabel Content="Wind" Postfix=" km/h" JoinIfEqual="True" Margin="0 0 0 4" Value="{Binding WindSpeedMin, StringFormat='{}{0:F0}'}"
                  SecondValue="{Binding WindSpeedMax, StringFormat='{}{0:F0}'}" />
              <mui:DoubleSlider Minimum="0" Maximum="35" From="{Binding WindSpeedMin}" To="{Binding WindSpeedMax}" TickFrequency="7"
                  TickPlacement="BottomRight" IsSnapToTickEnabled="False" SmallChange="7" LargeChange="7" BindingMode="FromToFixed" />
            </StackPanel>

            <!-- Time multiplier -->
            <StackPanel Margin="0 0 8 8" Grid.Row="1" Grid.Column="2">
              <mui:ValueLabel Value="{Binding TimeMultiplier}" Postfix="×" Content="{x:Static g:AppStrings.Drive_TimeMultiplerLabel}" Margin="0 0 0 4" />
              <Slider Minimum="0" Maximum="1" TickFrequency="0.2" TickPlacement="None" IsSnapToTickEnabled="False">
                <Slider.Value>
                  <Binding Path="TimeMultiplier">
                    <Binding.Converter>
                      <mui:LogarithmicScale Minimum="0" Middle="10" Maximum="60" />
                    </Binding.Converter>
                  </Binding>
                </Slider.Value>
              </Slider>
            </StackPanel>
          </Grid>

          <!-- Mode-specific config (PythonAppConfig) -->
          <ContentControl ContentTemplate="{StaticResource PythonAppConfig.Compact.Race}" Content="{Binding ModeViewModel.Config}"
              Visibility="{Binding ModeViewModel.Config, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=inverse}" />

          <!-- Mode-specific race settings -->
          <UniformGrid Columns="2" DataContext="{Binding ModeViewModel}"
              Visibility="{Binding Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=inverse}">

            <StackPanel Margin="{StaticResource ElementMargin}" Height="42" Background="Transparent"
                Visibility="{Binding ShowLapsNumber, Converter={StaticResource BooleanToVisibilityConverter}}">
              <mui:ValueLabel Value="{Binding LapsNumber}" Content="{x:Static g:AppStrings.Drive_RaceDuration}"
                  Postfix="{Binding LapsNumber, Converter={StaticResource PluralizingConverter}, ConverterParameter={x:Static c:ControlsStrings.Common_LapsPostfix}}" />
              <mui:FormattedSlider Minimum="0" Maximum="1" AutoToolTipPlacement="BottomRight">
                <Slider.Value>
                  <Binding Path="LapsNumber">
                    <Binding.Converter>
                      <mui:LogarithmicScale Minimum="1" Middle="40" Maximum="120" />
                    </Binding.Converter>
                  </Binding>
                </Slider.Value>
              </mui:FormattedSlider>
            </StackPanel>

            <StackPanel Margin="{StaticResource ElementMargin}" Height="42"
                Visibility="{Binding ShowPenalties, Converter={StaticResource BooleanToVisibilityConverter}}">
              <CheckBox Margin="8 8 0 0" IsChecked="{Binding Penalties}">
                <Label Content="{x:Static g:AppStrings.Drive_Penalties}" />
              </CheckBox>
            </StackPanel>

            <DockPanel Margin="{StaticResource ElementMargin}" Height="42" VerticalAlignment="Top"
                Visibility="{Binding ShowAiLevel, Converter={StaticResource BooleanToVisibilityConverter}}">
              <mui:DoubleSlider DockPanel.Dock="Bottom" Minimum="{Binding RaceGridViewModel.AiLevelMinimumLimited}" Maximum="100"
                  From="{Binding RaceGridViewModel.AiLevelMin, Converter={StaticResource SliderRoundConverter}, ConverterParameter=0.1}"
                  To="{Binding RaceGridViewModel.AiLevel, Converter={StaticResource SliderRoundConverter}, ConverterParameter=0.1}" SmallChange="5"
                  LargeChange="5" BindingMode="FromToFixed" />
              <mui:DoubleValueLabel Value="{Binding RaceGridViewModel.AiLevelMin}" SecondValue="{Binding RaceGridViewModel.AiLevel}" Postfix='%'
                  JoinIfEqual="True" Content="{x:Static g:AppStrings.Drive_OpponentsStrength}" />
            </DockPanel>

            <StackPanel Margin="{StaticResource ElementMargin}" Height="42"
                Visibility="{Binding ShowJumpStartPenalty, Converter={StaticResource BooleanToVisibilityConverter}}">
              <TextBlock Style="{StaticResource Label.Padding}" Text="{x:Static g:AppStrings.Drive_JumpStartPenalty}" Margin="0 0 0 4" />
              <ComboBox Margin="4 0 4 0" ItemsSource="{Binding JumpStartPenaltyTypes}" SelectedItem="{Binding JumpStartPenalty}"
                  mui:ComboBoxAdvancement.DisplayConverter="{x:Static dr:QuickDrive_Race+ViewModel.JumpStartPenaltyTypeToStringConverter}" />
            </StackPanel>

            <StackPanel Margin="{StaticResource ElementMargin}" Height="42"
                Visibility="{Binding AiLimit, Converter={StaticResource MoreToVisibilityConverter}, ConverterParameter=1}">
              <TextBlock Style="{StaticResource Label.Padding}" Text="{x:Static t:ToolsStrings.Drive_GridType}" Margin="0 0 0 4" />
              <mui:HierarchicalComboBox Margin="4 0 4 0" ItemsSource="{Binding RaceGridViewModel.Modes}" SelectedItem="{Binding RaceGridViewModel.Mode}"
                  FixedMode="False" PreviewProvider="{Binding}" />
            </StackPanel>

            <StackPanel Margin="{StaticResource ElementMargin}" Height="42" IsEnabled="{Binding RaceGridViewModel.Mode.CandidatesMode}"
                Visibility="{Binding AiLimit, Converter={StaticResource MoreToVisibilityConverter}, ConverterParameter=1}">
              <StackPanel.ToolTip>
                <ToolTip Content="{Binding RaceGridViewModel.TrackPitsNumber}"
                    ContentStringFormat="{x:Static g:AppStrings.Drive_OpponentsMaximumLimitation_Tooltip}" />
              </StackPanel.ToolTip>
              <mui:ValueLabel Value="{Binding RaceGridViewModel.OpponentsNumberLimited}"
                  Postfix="{Binding RaceGridViewModel.OpponentsNumberLimited, Converter={StaticResource PluralizingConverter}, ConverterParameter={x:Static c:ControlsStrings.Common_OpponentsPostfix}}" />
              <Slider Minimum="1" Maximum="{Binding RaceGridViewModel.OpponentsNumberLimit}" Value="{Binding RaceGridViewModel.OpponentsNumberLimited}" />
            </StackPanel>

            <StackPanel Margin="{StaticResource ElementMargin}" Height="42"
                Visibility="{Binding ShowStartingPositionSelection, Converter={StaticResource BooleanToVisibilityConverter}}">
              <StackPanel.ToolTip>
                <TextBlock>
                  <TextBlock.Text>
                    <MultiBinding Converter="{x:Static dr:QuickDrive_Race.StartingPositionConverter}">
                      <Binding Path="RaceGridViewModel.StartingPositionLimited" />
                      <Binding Path="RaceGridViewModel.StartingPositionLimit" />
                    </MultiBinding>
                  </TextBlock.Text>
                </TextBlock>
              </StackPanel.ToolTip>
              <mui:ValueLabel Content="{x:Static g:AppStrings.Drive_StartingPosition}" mui:BetterTextBox.Mode="Integer" mui:BetterTextBox.Minimum="0"
                  mui:BetterTextBox.Maximum="{Binding RaceGridViewModel.StartingPositionLimit}"
                  mui:BetterTextBox.Converter="{Binding StartingPositionInputConverter}">
                <mui:ValueLabel.Value>
                  <MultiBinding Converter="{x:Static dr:QuickDrive_Race.StartingPositionConverter}">
                    <Binding Path="RaceGridViewModel.StartingPositionLimited" Mode="TwoWay" />
                    <Binding Path="RaceGridViewModel.StartingPositionLimit" Mode="OneWay" />
                  </MultiBinding>
                </mui:ValueLabel.Value>
              </mui:ValueLabel>
              <Slider Minimum="0" Maximum="{Binding RaceGridViewModel.StartingPositionLimit}" Value="{Binding RaceGridViewModel.StartingPositionLimited}" />
            </StackPanel>
          </UniformGrid>

          <!-- Assists and Go button -->
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <c:UserPresetsControl UserPresetable="{Binding Source={x:Static c:AssistsViewModel.Instance}}" ShowSaveButton="False" Margin="0 0 4 0" />

            <ToggleButton x:Name="AssistsButton" Content="…" Margin="0 0 4 0"
                IsHitTestVisible="{Binding ElementName=AssistsPopup, Path=IsOpen, Mode=OneWay, Converter={StaticResource InvertBooleanConverter}}">
              <ToggleButton.ToolTip>
                <c:AssistsDescription DataContext="{Binding Source={x:Static c:AssistsViewModel.Instance}}" />
              </ToggleButton.ToolTip>
            </ToggleButton>
            <c:ModernPopup x:Name="AssistsPopup" PlacementTarget="{Binding ElementName=AssistsButton}" Placement="Top"
                IsOpen="{Binding IsChecked, ElementName=AssistsButton, Mode=TwoWay}" Padding="16 12 16 16">
              <uc:AssistsEditor DataContext="{Binding Source={x:Static c:AssistsViewModel.Instance}}" />
            </c:ModernPopup>

            <Button Command="{Binding GoCommand}" Style="{StaticResource Go.Button}" VerticalAlignment="Bottom" Content="{x:Static g:AppStrings.Common_Go}" />
          </StackPanel>

        </mui:SpacingStackPanel>
      </ScrollViewer>
    </Grid>
  </mui:Switch>
</UserControl>